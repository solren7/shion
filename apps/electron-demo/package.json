{
  "name": "komo-electron-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Electron desktop demo for komo — chat (@assistant-ui/react) + dashboard (TanStack Query) over the gateway's HTTP api channel. A JS sibling of crates/komo-gui.",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "@assistant-ui/store": "0.2.13"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.28",
    "@assistant-ui/react-markdown": "^0.12.11",
    "@assistant-ui/react-syntax-highlighter": "^0.12.9",
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
